<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="379.0" prefWidth="681.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_7_damagedItemsController">
    <children>
        <Label layoutX="211.0" layoutY="14.0" text="Damage and Expiry Management">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="14.0" layoutY="50.0" text="Item:" />
        <ComboBox fx:id="itemComboBox" layoutX="63.0" layoutY="46.0" prefHeight="25.0" prefWidth="188.0" promptText="Select Item" />

        <Label layoutX="14.0" layoutY="87.0" text="Condition:" />
        <ComboBox fx:id="conditionComboBox" layoutX="74.0" layoutY="83.0" prefHeight="25.0" prefWidth="177.0" promptText="Expired/Damaged" />

        <Label layoutX="17.0" layoutY="131.0" text="Quantity:" />
        <TextField fx:id="quantityTF" layoutX="77.0" layoutY="127.0" prefHeight="25.0" prefWidth="171.0" promptText="Enter quantity" />

        <Label layoutX="14.0" layoutY="173.0" text="Reason:" />
        <TextArea fx:id="reasonTA" layoutX="56.0" layoutY="160.0" prefHeight="60.0" prefWidth="201.0" promptText="Reason for removal" />

        <Button layoutX="9.0" layoutY="234.0" mnemonicParsing="false" onAction="#removeStockButtonOA" prefWidth="250.0" text="Remove Stock" />
        <TableView fx:id="removedItemsTV" layoutX="270.0" layoutY="50.0" prefHeight="281.0" prefWidth="403.0">
            <columns>
                <TableColumn fx:id="recordIdCol" prefWidth="80.0" text="Record ID" />
                <TableColumn fx:id="itemNameCol" prefWidth="84.0" text="Item" />
                <TableColumn fx:id="conditionCol" prefWidth="63.0" text="Condition" />
                <TableColumn fx:id="quantityCol" prefWidth="58.0" text="Qty" />
                <TableColumn fx:id="dateReportedCol" prefWidth="56.0" text="Date" />
                <TableColumn fx:id="statusCol" prefWidth="62.0" text="Status" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="270.0" layoutY="340.0" prefHeight="17.0" prefWidth="403.0" />

        <Label layoutX="16.0" layoutY="282.0" text="Filter by Condition:" />
        <ComboBox fx:id="filterConditionComboBox" layoutX="13.0" layoutY="306.0" prefWidth="120.0" />
        <Button layoutX="151.0" layoutY="306.0" mnemonicParsing="false" onAction="#filterButtonOA" text="Filter" />
        <Button layoutX="211.0" layoutY="306.0" mnemonicParsing="false" onAction="#resetFilterButtonOA" text="Reset" />
    </children>
</AnchorPane>
