<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="407.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_2_stockUsageController">
    <children>
        <Label layoutX="108.0" layoutY="14.0" text="Stock Usage Tracking">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="60.0" text="Department:" />
        <ComboBox fx:id="departmentComboBox" layoutX="120.0" layoutY="55.0" prefHeight="25.0" prefWidth="200.0" promptText="Select department" />

        <Label layoutX="20.0" layoutY="100.0" text="Item:" />
        <ComboBox fx:id="itemComboBox" layoutX="120.0" layoutY="95.0" prefHeight="25.0" prefWidth="200.0" promptText="Select item" />

        <Label layoutX="20.0" layoutY="140.0" text="Used Quantity:" />
        <TextField fx:id="quantityTF" layoutX="120.0" layoutY="135.0" prefHeight="25.0" prefWidth="200.0" promptText="Enter quantity used" />

        <Button layoutX="120.0" layoutY="168.0" onAction="#updateUsageButtonOA" prefHeight="25.0" prefWidth="150.0" text="Update Usage" />

        <TableView fx:id="usageTV" layoutX="20.0" layoutY="200.0" prefHeight="300.0" prefWidth="363.0">
            <columns>
                <TableColumn fx:id="departmentCol" prefWidth="203.0" text="Department" />
                <TableColumn fx:id="itemCol" prefWidth="203.0" text="Item" />
                <TableColumn fx:id="quantityCol" prefWidth="203.0" text="Used Quantity" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>
