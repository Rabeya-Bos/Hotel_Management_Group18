<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="342.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_11_additionalChargesController">
    <children>
        <Label layoutX="196.0" layoutY="23.0" text="Additional Charges Management">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20" layoutY="70" text="Guest ID" />
        <TextField fx:id="guestIdTF" layoutX="130" layoutY="65" prefWidth="200" />

        <Label layoutX="20" layoutY="120" text="Charge Type" />
        <ComboBox fx:id="chargeTypeComboBox" layoutX="130" layoutY="115" prefWidth="200" />

        <Label layoutX="20" layoutY="170" text="Charge Amount" />
        <TextField fx:id="amountTF" layoutX="130" layoutY="165" prefWidth="200" />

        <Button layoutX="180.0" layoutY="216.0" onAction="#addChargeButtonOA" prefWidth="150" text="Add Charge" />

        <Label fx:id="totalLabel" layoutX="20" layoutY="220" text="Total Amount: $0.00" />

        <TableView fx:id="chargeTV" layoutX="381.0" layoutY="54.0" prefHeight="250" prefWidth="239.0">
            <columns>
                <TableColumn fx:id="guestCol" text="Guest ID" />
                <TableColumn fx:id="chargeTypeCol" text="Charge Type" />
                <TableColumn fx:id="amountCol" text="Amount ($)" />
            </columns>
        </TableView>
      <Button layoutX="48.0" layoutY="279.0" mnemonicParsing="false" onAction="#backButtonOA" text="Back" />
      <Button layoutX="196.0" layoutY="279.0" mnemonicParsing="false" onAction="#nextButtonOA" text="Next" />
    </children>
</AnchorPane>
