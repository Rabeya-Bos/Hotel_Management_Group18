<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_1_recordSupplyController">
    <children>
        <Label layoutX="250.0" layoutY="20.0" text="Record Supply">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Label layoutX="50.0" layoutY="80.0" text="Date:" />
        <DatePicker fx:id="datePicker" layoutX="120.0" layoutY="80.0" prefWidth="200.0" />

        <Label layoutX="50.0" layoutY="130.0" text="Item:" />
        <ComboBox fx:id="itemComboBox" layoutX="120.0" layoutY="130.0" prefWidth="200.0" promptText="Select Item" />

        <Label layoutX="50.0" layoutY="180.0" text="Quantity:" />
        <TextField fx:id="quantityTF" layoutX="120.0" layoutY="180.0" prefWidth="200.0" promptText="Enter quantity" />

        <Button layoutX="150.0" layoutY="240.0" mnemonicParsing="false" onAction="#saveSupplyButtonOA" prefWidth="150.0" text="Save Supply" />

        <TableView fx:id="supplyTV" layoutX="350.0" layoutY="80.0" prefHeight="250.0" prefWidth="250.0">
            <columns>
                <TableColumn fx:id="dateCol" maxWidth="800.0" minWidth="30.0" prefWidth="80.0" text="Date" />
                <TableColumn fx:id="itemCol" maxWidth="850.0" minWidth="30.0" prefWidth="85.0" text="Item" />
                <TableColumn fx:id="quantityCol" maxWidth="700.0" minWidth="30.0" prefWidth="70.0" text="Quantity" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="50.0" layoutY="300.0" prefWidth="550.0" />
      <Button layoutX="519.0" layoutY="352.0" mnemonicParsing="false" onAction="#nextButtonOA" prefHeight="25.0" prefWidth="67.0" text="Next" />
    </children>
</AnchorPane>
