<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="552.0" prefWidth="514.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_4_inventoryReportController">
    <children>
        <Label layoutX="155.0" layoutY="15.0" text="Inventory Report Generation">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="55.0" text="Category" />
        <ComboBox fx:id="categoryComboBox" layoutX="120.0" layoutY="50.0" prefHeight="25.0" prefWidth="200.0" promptText="Select category" />

        <Label layoutX="20.0" layoutY="95.0" text="Report Type" />

        <RadioButton fx:id="dailyRB" layoutX="120.0" layoutY="95.0" selected="true" text="Daily">
            <toggleGroup>
                <ToggleGroup fx:id="reportTypeGroup" />
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="monthlyRB" layoutX="200.0" layoutY="95.0" text="Monthly" toggleGroup="$reportTypeGroup" />

        <Button layoutX="350.0" layoutY="90.0" onAction="#generateReportButtonOA" prefHeight="25.0" prefWidth="150.0" text="Generate Report" />

        <TableView fx:id="reportTV" layoutX="20.0" layoutY="140.0" prefHeight="350.0" prefWidth="474.0">
            <columns>
                <TableColumn fx:id="categoryCol" prefWidth="158.0" text="Category" />
                <TableColumn fx:id="dateCol" prefWidth="158.0" text="Date" />
                <TableColumn fx:id="quantityCol" prefWidth="158.0" text="Quantity" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
      <Button layoutX="42.0" layoutY="504.0" mnemonicParsing="false" onAction="#backButtonOA" text="Back" />
      <Button layoutX="413.0" layoutY="504.0" mnemonicParsing="false" onAction="#nextButtonOA" text="Next" />
    </children>
</AnchorPane>
