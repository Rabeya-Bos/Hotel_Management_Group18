<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="505.0" prefWidth="372.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_3_lowStockController">
    <children>
        <Label layoutX="90.0" layoutY="14.0" text="Low Stock Management">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="60.0" text="Threshold Quantity:" />
        <TextField fx:id="thresholdTF" layoutX="140.0" layoutY="56.0" prefHeight="25.0" prefWidth="200.0" promptText="Enter threshold value" />

        <Button layoutX="105.0" layoutY="101.0" onAction="#setThresholdButtonOA" prefHeight="40.0" prefWidth="150.0" text="Set Threshold" />

        <TableView fx:id="stockTV" layoutX="21.0" layoutY="164.0" prefHeight="287.0" prefWidth="319.0">
            <columns>
                <TableColumn fx:id="itemCol" prefWidth="203.0" text="Item Name" />
                <TableColumn fx:id="currentStockCol" prefWidth="203.0" text="Current Stock" />
                <TableColumn fx:id="thresholdCol" prefWidth="203.0" text="Threshold" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
      <Button layoutX="46.0" layoutY="460.0" mnemonicParsing="false" onAction="#backButtonOA" text="Back" />
      <Button layoutX="266.0" layoutY="460.0" mnemonicParsing="false" onAction="#nextButtonOA" text="Next" />
    </children>
</AnchorPane>
