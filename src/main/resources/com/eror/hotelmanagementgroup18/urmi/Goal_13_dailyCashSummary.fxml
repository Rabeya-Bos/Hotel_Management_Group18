<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_13_dailyCashSummaryController">
    <children>
        <Label layoutX="250.0" layoutY="20.0" text="Daily Cash Summary">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="30.0" layoutY="70.0" text="Select Date:" />
        <DatePicker fx:id="datePicker" layoutX="120.0" layoutY="65.0" prefHeight="30.0" prefWidth="150.0" promptText="YYYY-MM-DD" />

        <Button text="Generate Summary" layoutX="300.0" layoutY="65.0" mnemonicParsing="false" onAction="#generateSummary" prefHeight="30.0" prefWidth="160.0" />

        <TableView fx:id="summaryTable" layoutX="30.0" layoutY="120.0" prefHeight="340.0" prefWidth="640.0">
            <columns>
                <TableColumn fx:id="transactionIdCol" prefWidth="160.0" text="Transaction ID" />
                <TableColumn fx:id="paymentMethodCol" prefWidth="200.0" text="Payment Method" />
                <TableColumn fx:id="amountCol" prefWidth="150.0" text="Amount" />
                <TableColumn fx:id="dateCol" prefWidth="130.0" text="Date" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>