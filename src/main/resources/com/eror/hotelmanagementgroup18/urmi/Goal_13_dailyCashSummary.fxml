<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="523.0" prefWidth="514.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_13_dailyCashSummaryController">
    <children>
        <Label layoutX="175.0" layoutY="22.0" text="Daily Cash Summary">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="30.0" layoutY="70.0" text="Select Date:" />
        <DatePicker fx:id="datePicker" layoutX="120.0" layoutY="65.0" prefHeight="30.0" prefWidth="150.0" promptText="YYYY-MM-DD" />

        <Button layoutX="300.0" layoutY="65.0" mnemonicParsing="false" onAction="#generateSummary" prefHeight="30.0" prefWidth="160.0" text="Generate Summary" />

        <TableView fx:id="summaryTable" layoutX="62.0" layoutY="125.0" prefHeight="340.0" prefWidth="379.0">
            <columns>
                <TableColumn fx:id="transactionIdCol" prefWidth="160.0" text="Transaction ID" />
                <TableColumn fx:id="paymentMethodCol" prefWidth="200.0" text="Payment Method" />
                <TableColumn fx:id="amountCol" prefWidth="150.0" text="Amount" />
                <TableColumn fx:id="dateCol" prefWidth="130.0" text="Date" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
      <Button layoutX="67.0" layoutY="475.0" mnemonicParsing="false" onAction="#backButtonOA" text="Back" />
      <Button layoutX="389.0" layoutY="475.0" mnemonicParsing="false" onAction="#nextButtonOA" text="Next" />
    </children>
</AnchorPane>
