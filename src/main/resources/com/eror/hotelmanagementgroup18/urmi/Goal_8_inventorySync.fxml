<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="397.0" prefWidth="647.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_8_inventorySyncConroller">
    <children>
        <Label layoutX="215.0" layoutY="14.0" text="Inventory Synchronization System">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="14.0" layoutY="50.0" text="Connected Departments" />

        <Button layoutX="23.0" layoutY="124.0" mnemonicParsing="false" onAction="#syncInventoryButtonOA" prefWidth="250.0" text="Sync Inventory" />

        <Label fx:id="syncStatusLabel" layoutX="14.0" layoutY="286.0" prefHeight="51.0" prefWidth="250.0" />

        <Label layoutX="300.0" layoutY="50.0" text="Synchronization Log" />
        <TableView fx:id="syncLogTV" layoutX="300.0" layoutY="70.0" prefHeight="300.0" prefWidth="338.0">
            <columns>
                <TableColumn fx:id="timestampCol" prefWidth="120.0" text="Timestamp" />
                <TableColumn fx:id="departmentCol" prefWidth="120.0" text="Department" />
                <TableColumn fx:id="statusCol" prefWidth="100.0" text="Status" />
            </columns>
        </TableView>

        <Label fx:id="messageLabel" layoutX="300.0" layoutY="380.0" prefWidth="380.0" />

        <Button layoutX="23.0" layoutY="188.0" mnemonicParsing="false" onAction="#viewDetailsButtonOA" text="View Details" />
        <Button layoutX="127.0" layoutY="188.0" mnemonicParsing="false" onAction="#refreshButtonOA" text="Refresh" />
        <TextField fx:id="connectedDepartmentsTF" layoutX="23.0" layoutY="80.0" prefHeight="25.0" prefWidth="250.0" />
      <Button layoutX="69.0" layoutY="245.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="25.0" prefWidth="81.0" text="Back" />
    </children>
</AnchorPane>
