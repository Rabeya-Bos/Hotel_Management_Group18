<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="587.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_14_paymentMethodController">
    <children>
        <Label layoutX="179.0" layoutY="21.0" text="Payment Method Processing">
            <font>
                <Font name="System Bold" size="15.0" />
            </font></Label>

        <Label layoutX="50.0" layoutY="60.0" text="Invoice / Booking ID:" />
        <TextField fx:id="invoiceIdTF" layoutX="200.0" layoutY="60.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="110.0" text="Guest Name:" />
        <TextField fx:id="guestNameTF" editable="false" layoutX="200.0" layoutY="110.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="160.0" text="Total Amount:" />
        <TextField fx:id="totalAmountTF" editable="false" layoutX="200.0" layoutY="160.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="210.0" text="Select Payment Method:" />

        <RadioButton fx:id="cashRadio" layoutX="200.0" layoutY="210.0" selected="true" text="Cash">
            <toggleGroup>
                <ToggleGroup fx:id="paymentGroup" />
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="cardRadio" layoutX="280.0" layoutY="210.0" text="Card" toggleGroup="$paymentGroup" />
        <RadioButton fx:id="onlineRadio" layoutX="350.0" layoutY="210.0" text="Online" toggleGroup="$paymentGroup" />

        <Label layoutX="50.0" layoutY="260.0" text="Card Number:" />
        <TextField fx:id="cardNumberTF" disable="true" layoutX="200.0" layoutY="260.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="310.0" text="Transaction ID:" />
        <TextField fx:id="transactionIdTF" disable="true" layoutX="200.0" layoutY="310.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="360.0" text="Amount Paid:" />
        <TextField fx:id="amountPaidTF" layoutX="200.0" layoutY="360.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="410.0" text="Change:" />
        <TextField fx:id="changeTF" editable="false" layoutX="200.0" layoutY="410.0" prefWidth="300.0" />

        <Button layoutX="94.0" layoutY="450.0" mnemonicParsing="false" onAction="#processPaymentButtonOA" prefHeight="25.0" prefWidth="189.0" text="Process Payment" />
        <Button layoutX="296.0" layoutY="450.0" mnemonicParsing="false" onAction="#resetButtonOA" prefHeight="25.0" prefWidth="214.0" text="Reset" />

        <Label fx:id="statusLabel" layoutX="47.0" layoutY="485.0" prefHeight="40.0" prefWidth="498.0" />
      <Button layoutX="100.0" layoutY="548.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="25.0" prefWidth="171.0" text="Back" />
      <Button layoutX="311.0" layoutY="548.0" mnemonicParsing="false" onAction="#nextButtonOA" prefHeight="25.0" prefWidth="171.0" text="Next" />
    </children>
</AnchorPane>
