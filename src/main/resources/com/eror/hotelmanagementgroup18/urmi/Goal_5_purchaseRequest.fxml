<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="511.0" prefWidth="663.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_5_purchaseRequestController">
    <children>
        <Label layoutX="150.0" layoutY="15.0" text="Purchase Request Management">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Label layoutX="15.0" layoutY="82.0" text="Select Item:" />
        <ComboBox fx:id="itemComboBox" layoutX="86.0" layoutY="75.0" prefHeight="30.0" prefWidth="140.0" promptText="Choose item..." />

        <Label layoutX="15.0" layoutY="115.0" text="Quantity:" />
        <TextField fx:id="quantityTF" layoutX="80.0" layoutY="117.0" prefHeight="30.0" prefWidth="140.0" promptText="Enter quantity" />

        <Label layoutX="11.0" layoutY="161.0" text="Reason for Request:" />
        <TextArea fx:id="reasonRequestTA" layoutX="15.0" layoutY="195.0" prefHeight="60.0" prefWidth="200.0" promptText="Enter reason..." />

        <Label layoutX="15.0" layoutY="265.0" text="Vendor:" />
        <ComboBox fx:id="vendorComboBox" layoutX="64.0" layoutY="267.0" prefHeight="30.0" prefWidth="147.0" promptText="Select vendor" />

        <Button layoutX="15.0" layoutY="330.0" mnemonicParsing="false" onAction="#sendRequestButtonOA" prefHeight="30.0" prefWidth="200.0" text="Send Request" />
        <Button layoutX="15.0" layoutY="370.0" mnemonicParsing="false" onAction="#clearFormButtonOA" prefHeight="30.0" prefWidth="200.0" text="Clear Form" />

        <Label layoutX="240.0" layoutY="55.0" text="Purchase Requests History" />
        <TableView fx:id="requestTV" layoutX="240.0" layoutY="75.0" prefHeight="280.0" prefWidth="373.0">
            <columns>
                <TableColumn fx:id="requestIdCol" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="itemNameCol" prefWidth="80.0" text="Item" />
                <TableColumn fx:id="quantityCol" prefWidth="60.0" text="Qty" />
                <TableColumn fx:id="vendorCol" prefWidth="80.0" text="Vendor" />
                <TableColumn fx:id="requestDateCol" prefWidth="70.0" text="Date" />
                <TableColumn fx:id="statusCol" prefWidth="60.0" text="Status" />
            <TableColumn fx:id="reasonCol" prefWidth="60.0" text="Reason" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Label layoutX="240.0" layoutY="365.0" text="Filter by Status:" />
        <ComboBox fx:id="filterStatusComboBox" layoutX="340.0" layoutY="360.0" prefHeight="30.0" prefWidth="120.0" promptText="All" />

        <Button layoutX="240.0" layoutY="405.0" mnemonicParsing="false" onAction="#filterButtonOA" prefHeight="30.0" prefWidth="80.0" text="Filter" />
        <Button layoutX="330.0" layoutY="405.0" mnemonicParsing="false" onAction="#resetFilterButtonOA" prefHeight="30.0" prefWidth="80.0" text="Reset" />

        <Label fx:id="statusLabel" layoutX="123.0" layoutY="450.0" prefHeight="50.0" prefWidth="462.0" style="-fx-background-color: #f0f0f0; -fx-padding: 8;" wrapText="true" />
      <Button layoutX="37.0" layoutY="463.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="25.0" prefWidth="62.0" text="Back" />
      <Button layoutX="593.0" layoutY="463.0" mnemonicParsing="false" onAction="#nextButtonOA" prefHeight="25.0" prefWidth="62.0" text="Next" />
    </children>
</AnchorPane>
