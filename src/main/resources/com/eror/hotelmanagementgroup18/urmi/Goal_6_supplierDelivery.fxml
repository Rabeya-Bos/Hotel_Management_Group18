<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="436.0" prefWidth="614.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_6_supplierDeliveryController">
    <children>
        <Label layoutX="201.0" layoutY="14.0" prefHeight="42.0" prefWidth="193.0" text="Supplier Delivery Tracking">
            <font>
                <Font name="System Bold" size="15.0" />
            </font></Label>

        <Label layoutX="14.0" layoutY="50.0" text="Verify Delivery" />

        <Label layoutX="14.0" layoutY="80.0" text="Supplier:" />
        <ComboBox fx:id="supplierComboBox" layoutX="74.0" layoutY="76.0" prefHeight="25.0" prefWidth="154.0" promptText="Select Supplier" />

        <Label layoutX="14.0" layoutY="140.0" text="Delivery ID:" />
        <TextField fx:id="deliveryIdTF" layoutX="84.0" layoutY="136.0" prefHeight="25.0" prefWidth="144.0" promptText="Enter Delivery ID" />

        <Button layoutX="14.0" layoutY="176.0" mnemonicParsing="false" onAction="#verifyDeliveryButtonOA" prefHeight="25.0" prefWidth="220.0" text="Verify Delivery" />

        <Label layoutX="15.0" layoutY="238.0" text="Delivery Details" />

        <Label layoutX="15.0" layoutY="268.0" text="Item:" />
        <Label fx:id="itemLabel" layoutX="14.0" layoutY="300.0" prefWidth="250.0" style="-fx-background-color: #f0f0f0;" />

        <Label layoutX="14.0" layoutY="297.0" text="Quantity Ordered:" />
        <Label fx:id="quantityOrderedLabel" layoutX="14.0" layoutY="350.0" prefWidth="250.0" style="-fx-background-color: #f0f0f0;" />

        <Label layoutX="13.0" layoutY="330.0" text="Quantity Received:" />
        <TextField fx:id="quantityReceivedTF" layoutX="129.0" layoutY="326.0" prefHeight="25.0" prefWidth="110.0" />

        <Button layoutX="15.0" layoutY="355.0" mnemonicParsing="false" onAction="#updateInventoryButtonOA" prefWidth="250.0" text="Update Inventory" />
        <TableView fx:id="deliveryTV" layoutX="276.0" layoutY="79.0" prefHeight="243.0" prefWidth="314.0">
            <columns>
                <TableColumn fx:id="deliveryIdCol" prefWidth="67.0" text="Delivery ID" />
                <TableColumn fx:id="supplierCol" prefWidth="54.0" text="Supplier" />
                <TableColumn fx:id="itemCol" prefWidth="32.0" text="Item" />
                <TableColumn fx:id="orderedCol" minWidth="0.0" prefWidth="58.0" text="Ordered" />
                <TableColumn fx:id="receivedCol" prefWidth="60.0" text="Received" />
                <TableColumn fx:id="statusCol" prefWidth="40.0" text="Status" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="277.0" layoutY="334.0" prefHeight="17.0" prefWidth="314.0" />

        <Label layoutX="297.0" layoutY="369.0" text="Search PO:" />
        <TextField fx:id="searchPOTF" layoutX="370.0" layoutY="365.0" prefWidth="200.0" promptText="PO ID" />
        <Button layoutX="370.0" layoutY="394.0" mnemonicParsing="false" onAction="#searchButtonOA" prefHeight="25.0" prefWidth="200.0" text="Search" />
        <Button layoutX="298.0" layoutY="394.0" mnemonicParsing="false" onAction="#refreshButtonOA" text="Refresh" />
        <TextField fx:id="quantityOrdredTF" layoutX="129.0" layoutY="293.0" prefHeight="25.0" prefWidth="110.0" />
        <TextField fx:id="itemTF" layoutX="129.0" layoutY="264.0" prefHeight="25.0" prefWidth="110.0" />
    </children>
</AnchorPane>
