<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="519.0" prefWidth="736.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.urmi.Goal_15_transactionSearchController">
    <children>
        <Label layoutX="300.0" layoutY="14.0" text="Transaction Search">
            <font>
                <Font name="System Bold" size="17.0" />
            </font></Label>

        <Label layoutX="14.0" layoutY="50.0" text="Search By:" />
        <ComboBox fx:id="searchByComboBox" layoutX="14.0" layoutY="70.0" prefWidth="200.0" />

        <Label layoutX="14.0" layoutY="120.0" text="Search Value:" />
        <TextField fx:id="searchValueTF" layoutX="14.0" layoutY="140.0" prefWidth="200.0" promptText="Enter search value" />

        <Label layoutX="14.0" layoutY="190.0" text="Date Range:" />
        <DatePicker fx:id="fromDatePicker" layoutX="14.0" layoutY="210.0" prefWidth="120.0" promptText="From" />
        <DatePicker fx:id="toDatePicker" layoutX="150.0" layoutY="210.0" prefWidth="120.0" promptText="To" />

        <Button layoutX="14.0" layoutY="260.0" mnemonicParsing="false" onAction="#searchButtonOA" prefWidth="120.0" text="Search" />
        <Button layoutX="150.0" layoutY="260.0" mnemonicParsing="false" onAction="#resetButtonOA" prefWidth="120.0" text="Reset" />

        <TableView fx:id="transactionTV" layoutX="280.0" layoutY="50.0" prefHeight="400.0" prefWidth="425.0">
            <columns>
                <TableColumn fx:id="transactionIdCol" prefWidth="89.0" text="Transaction ID" />
                <TableColumn fx:id="invoiceIdCol" prefWidth="67.0" text="Invoice ID" />
                <TableColumn fx:id="guestNameCol" prefWidth="92.0" text="Guest Name" />
                <TableColumn fx:id="amountCol" prefWidth="52.0" text="Amount" />
                <TableColumn fx:id="paymentCol" prefWidth="62.0" text="Payment" />
                <TableColumn fx:id="dateCol" prefWidth="62.0" text="Date" />
            </columns>
        </TableView>

        <Label fx:id="resultCountLabel" layoutX="280.0" layoutY="460.0" text="0 transactions found" />

        <Button layoutX="603.0" layoutY="465.0" mnemonicParsing="false" onAction="#viewDetailsButtonOA" text="View Details" />

        <Label fx:id="statusLabel" layoutX="14.0" layoutY="310.0" prefWidth="250.0" />
    </children>
</AnchorPane>
