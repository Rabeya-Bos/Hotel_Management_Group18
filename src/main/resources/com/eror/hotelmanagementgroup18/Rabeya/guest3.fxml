<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eror.hotelmanagementgroup18.Rabeya.Guest3"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Title -->
    <Label layoutX="320.0" layoutY="20.0" text="In-Room Dining" textFill="#640ee3">
        <font>
            <Font size="24.0" />
        </font>
    </Label>

    <!-- Meal Category -->
    <Label layoutX="50.0" layoutY="84.0" text="Meal Category:" />
    <ComboBox fx:id="mealCategoryCombo" layoutX="150.0" layoutY="79.0" prefWidth="200.0" />

    <!-- Menu Table -->
    <Label layoutX="50.0" layoutY="105.0" prefHeight="18.0" prefWidth="200.0" />
    <TableView fx:id="menuTable" layoutX="50.0" layoutY="130.0" prefHeight="180.0" prefWidth="750.0">
        <columns>
            <TableColumn fx:id="itemIdCol" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="itemNameCol" prefWidth="200.0" text="Item" />
            <TableColumn fx:id="itemDescCol" prefWidth="250.0" text="Description" />
            <TableColumn fx:id="itemPriceCol" prefWidth="100.0" text="Price" />
            <TableColumn fx:id="itemCategoryCol" prefWidth="120.0" text="Category" />
        </columns>
    </TableView>

    <!-- Item Selection -->
    <Label layoutX="50.0" layoutY="320.0" text="Select Item:" />
    <ComboBox fx:id="itemSelectCombo" layoutX="150.0" layoutY="315.0" prefWidth="200.0" />

    <Label layoutX="370.0" layoutY="320.0" text="Quantity:" />
    <ComboBox fx:id="quantityCombo" layoutX="430.0" layoutY="315.0" prefWidth="80.0" />

    <Button layoutX="530.0" layoutY="315.0" onAction="#addToCartBtn" prefWidth="100.0" text="Add to Cart" />

    <!-- Cart Table -->
    <Label layoutX="50.0" layoutY="360.0" text="Your Cart:" />
    <TableView fx:id="cartTable" layoutX="50.0" layoutY="380.0" prefHeight="120.0" prefWidth="750.0">
        <columns>
            <TableColumn fx:id="cartItemCol" prefWidth="300.0" text="Item" />
            <TableColumn fx:id="cartQtyCol" prefWidth="80.0" text="Qty" />
            <TableColumn fx:id="cartPriceCol" prefWidth="100.0" text="Price" />
            <TableColumn fx:id="cartTotalCol" prefWidth="100.0" text="Total" />
        </columns>
    </TableView>

    <!-- Cart Total -->
    <Label layoutX="736.0" layoutY="580.0" prefHeight="18.0" prefWidth="80.0" />
    <Label fx:id="cartTotalLabel" layoutX="720.0" layoutY="541.0" prefHeight="18.0" prefWidth="112.0" />

    <!-- Delivery Time -->
    <Label layoutX="50.0" layoutY="520.0" text="Delivery Time:" />
    <ComboBox fx:id="deliveryTimeCombo" layoutX="150.0" layoutY="515.0" prefWidth="150.0" />

    <!-- Special Notes -->
    <Label layoutX="320.0" layoutY="520.0" text="Special Notes:" />
    <TextArea fx:id="specialNotesArea" layoutX="405.0" layoutY="511.0" prefHeight="60.0" prefWidth="300.0" />

    <!-- Buttons -->
    <Button layoutX="300.0" layoutY="590.0" onAction="#placeOrderBtn" prefWidth="150.0" text="Place Order" />
    <Button layoutX="500.0" layoutY="590.0" onAction="#returnHomeBtn" prefWidth="150.0" text="Return Home" />

    <!-- Order Confirmation -->
    <Label fx:id="orderConfirmationMsg" layoutX="300.0" layoutY="620.0" text="" />



</AnchorPane>
