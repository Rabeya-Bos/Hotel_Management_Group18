<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Rabeya.Receptionist7">

    <!-- Title -->
    <Label layoutX="250.0" layoutY="20.0" text="Guest Complaint Resolution">
        <font>
            <Font size="20.0" />
        </font>
    </Label>

    <!-- Complaints Table -->
    <Label layoutX="50.0" layoutY="60.0" text="Complaints List:" />
    <TableView fx:id="complaintsTable" layoutX="50.0" layoutY="80.0" prefHeight="150.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="complaintIdCol" prefWidth="60.0" text="ID" />
            <TableColumn fx:id="guestNameCol" prefWidth="150.0" text="Guest" />
            <TableColumn fx:id="complaintTypeCol" prefWidth="120.0" text="Type" />
            <TableColumn fx:id="priorityCol" prefWidth="80.0" text="Priority" />
            <TableColumn fx:id="complaintStatusCol" prefWidth="100.0" text="Status" />
        </columns>
    </TableView>

    <!-- Complaint Details -->
    <Label layoutX="50.0" layoutY="250.0" text="Complaint Details:" />
    <TextArea fx:id="complaintDetailsArea" editable="false" layoutX="50.0" layoutY="270.0" prefHeight="80.0" prefWidth="600.0" promptText="Select a complaint to view details" />

    <!-- Resolution Notes -->
    <Label layoutX="50.0" layoutY="360.0" text="Resolution Notes:" />
    <TextArea fx:id="resolutionNotesArea" layoutX="50.0" layoutY="380.0" prefHeight="60.0" prefWidth="600.0" promptText="Enter resolution details..." />

    <!-- Compensation Type -->
    <Label layoutX="50.0" layoutY="460.0" text="Compensation Type:" />
    <ComboBox fx:id="compensationCombo" layoutX="180.0" layoutY="455.0" prefWidth="250.0" promptText="Select compensation" />

    <!-- Action Buttons -->
    <Button layoutX="200.0" layoutY="510.0" onAction="#resolveBtn" prefWidth="150.0" text="Resolve Complaint" />
    <Button layoutX="370.0" layoutY="510.0" onAction="#escalateBtn" prefWidth="150.0" text="Escalate to Manager" />

    <!-- Resolution Status -->
    <Label fx:id="statusLabel" layoutX="200.0" layoutY="560.0" prefWidth="400.0" text="" wrapText="true" />
   <Button layoutX="564.0" layoutY="536.0" onAction="#homeBtn" prefWidth="100.0" text="Return Home" />

</AnchorPane>
