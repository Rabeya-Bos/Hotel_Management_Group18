<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User7Goal2Controller">
    <children>
        <Pane prefHeight="80.0" prefWidth="900.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label layoutX="30.0" layoutY="22.0" text="PAYROLL MANAGEMENT SYSTEM" textFill="#e1b12c">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Button layoutX="800.0" layoutY="25.0" onAction="#handleBackBtn" style="-fx-background-color: #e1b12c;" text="Go Back" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </Pane>

        <Pane layoutX="30.0" layoutY="100.0" prefHeight="150.0" prefWidth="840.0" style="-fx-background-color: white; -fx-background-radius: 10;">
            <children>
                <TextField fx:id="staffNameField" layoutX="20.0" layoutY="20.0" promptText="Staff Name" />
                <TextField fx:id="staffIdField" layoutX="20.0" layoutY="65.0" promptText="Staff ID" />
                <ComboBox fx:id="monthCombo" layoutX="20.0" layoutY="110.0" prefWidth="150.0" promptText="Select Month" />

                <TextField fx:id="basePayField" layoutX="220.0" layoutY="20.0" promptText="Base Salary" />
                <TextField fx:id="overtimeField" layoutX="220.0" layoutY="65.0" promptText="Overtime Bonus" />
                <TextField fx:id="bonusField" layoutX="220.0" layoutY="110.0" promptText="Service Bonus" />

                <Button layoutX="420.0" layoutY="105.0" onAction="#handleProcessBtn" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #27ae60;" text="Process Payroll" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </Pane>

        <TableView fx:id="payrollTable" layoutX="30.0" layoutY="270.0" prefHeight="300.0" prefWidth="840.0">
            <columns>
                <TableColumn fx:id="colStaffId" prefWidth="100.0" text="Staff ID" />
                <TableColumn fx:id="colName" prefWidth="200.0" text="Employee Name" />
                <TableColumn fx:id="colBasePay" prefWidth="150.0" text="Base Salary" />
                <TableColumn fx:id="colOvertime" prefWidth="150.0" text="Overtime" />
                <TableColumn fx:id="colTotal" prefWidth="238.0" text="Net Payable Salary" />
            </columns>
        </TableView>
    </children>
</AnchorPane>