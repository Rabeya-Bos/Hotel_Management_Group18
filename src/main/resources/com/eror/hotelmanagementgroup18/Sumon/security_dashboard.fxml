<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.SecurityDashboardController">
    <children>
        <Label layoutX="320.0" layoutY="40.0" text="Security Dashboard">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>
        <GridPane hgap="15.0" layoutX="50.0" layoutY="120.0" prefHeight="420.0" prefWidth="750.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Button fx:id="btn1" prefHeight="100.0" prefWidth="380.0" text="Access Card Management" />
                <Button fx:id="btn2" prefHeight="100.0" prefWidth="380.0" text="Incident Reporting" GridPane.columnIndex="1" />

                <Button fx:id="btn3" prefHeight="100.0" prefWidth="380.0" text="Surveillance Operation" GridPane.rowIndex="1" />
                <Button fx:id="btn4" prefHeight="100.0" prefWidth="380.0" text="Emergency Response Log" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Button fx:id="btn5" prefHeight="100.0" prefWidth="380.0" text="CCTV Monitoring" GridPane.rowIndex="2" />
                <Button fx:id="btn6" prefHeight="100.0" prefWidth="380.0" text="VIP Parking Allocation" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Button fx:id="btn7" prefHeight="100.0" prefWidth="380.0" text="Lost and Found Registry" GridPane.rowIndex="3" />
                <Button fx:id="btn8" prefHeight="100.0" prefWidth="380.0" text="Restricted Zone Control" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>
    </children>
</AnchorPane>