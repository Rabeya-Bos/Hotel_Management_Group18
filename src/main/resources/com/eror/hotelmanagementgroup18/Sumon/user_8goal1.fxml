<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f3f6;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User8Goal1Controller">
    <children>
        <Pane prefHeight="90.0" prefWidth="900.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label layoutX="30.0" layoutY="28.0" text="ACCESS CARD CONTROL SYSTEM" textFill="#ecf0f1">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Button layoutX="800.0" layoutY="30.0" onAction="#handleBackBtn" style="-fx-background-color: #bdc3c7;" text="BACK">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </Pane>

        <Pane layoutX="30.0" layoutY="110.0" prefHeight="100.0" prefWidth="840.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <children>
                <TextField fx:id="staffIdField" layoutX="25.0" layoutY="33.0" prefHeight="35.0" prefWidth="200.0" promptText="Enter Staff ID" />
                <ComboBox fx:id="levelCombo" layoutX="250.0" layoutY="33.0" prefHeight="35.0" prefWidth="200.0" promptText="Select Access Level" />
                <Button layoutX="480.0" layoutY="33.0" onAction="#handleUpdateBtn" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #27ae60;" text="Update Access Card" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </Pane>

        <TableView fx:id="cardTable" layoutX="30.0" layoutY="230.0" prefHeight="340.0" prefWidth="840.0">
            <columns>
                <TableColumn fx:id="colStaffId" prefWidth="200.0" text="Staff ID" />
                <TableColumn fx:id="colLevel" prefWidth="300.0" text="Access Permissions" />
                <TableColumn fx:id="colStatus" prefWidth="338.0" text="Card Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>