<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User7Goal3Controller">
    <children>
        <Pane prefHeight="100.0" prefWidth="900.0" style="-fx-background-color: #1a252f;">
            <children>
                <Label layoutX="30.0" layoutY="35.0" text="PREMIUM PRICING CONTROLS" textFill="#d4af37">
                    <font><Font name="System Bold" size="26.0" /></font>
                </Label>
                <Button layoutX="800.0" layoutY="38.0" onAction="#handleBackBtn" style="-fx-background-color: #d4af37; -fx-cursor: hand;" text="GO BACK" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </Pane>

        <VBox layoutX="30.0" layoutY="120.0" prefHeight="160.0" prefWidth="840.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <children>
                <HBox spacing="20.0">
                    <children>
                        <ComboBox fx:id="seasonCombo" prefHeight="35.0" prefWidth="200.0" promptText="Select Season/Event" />
                        <TextField fx:id="roomIdField" prefHeight="35.0" prefWidth="150.0" promptText="Room ID" />
                        <TextField fx:id="currentRateField" prefHeight="35.0" prefWidth="150.0" promptText="Current Rate ($)" />
                    </children>
                </HBox>
                <HBox spacing="20.0">
                    <children>
                        <TextField fx:id="multiplierField" prefHeight="35.0" prefWidth="150.0" promptText="Multiplier (e.g. 1.5)" />
                        <TextField fx:id="newRateField" editable="false" prefHeight="35.0" prefWidth="200.0" promptText="New Seasonal Rate (Auto)" style="-fx-background-color: #ecf0f1;" />
                        <Button onAction="#handleAddBtn" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-cursor: hand;" text="APPLY PRICING" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

        <TableView fx:id="pricingTable" layoutX="30.0" layoutY="300.0" prefHeight="270.0" prefWidth="840.0">
            <columns>
                <TableColumn fx:id="colRoomId" prefWidth="150.0" text="Room Number" />
                <TableColumn fx:id="colCurrentRate" prefWidth="200.0" text="Standard Rate" />
                <TableColumn fx:id="colMultiplier" prefWidth="150.0" text="Seasonal Multiplier" />
                <TableColumn fx:id="colNewRate" prefWidth="338.0" text="Calculated Seasonal Rate" />
            </columns>
        </TableView>
    </children>
</AnchorPane>