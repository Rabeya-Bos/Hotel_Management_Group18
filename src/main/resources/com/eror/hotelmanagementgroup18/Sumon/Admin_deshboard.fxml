<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.AdmindeshboardController">
    <children>
        <Pane prefHeight="90.0" prefWidth="900.0" style="-fx-background-color: #1a252f; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
            <children>
                <Label layoutX="30.0" layoutY="30.0" text="LUXURY HOTEL MANAGEMENT" textFill="#d4af37">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Label layoutX="430.0" layoutY="35.0" text="ADMIN DASHBOARD" textFill="WHITE">
                    <font><Font size="18.0" /></font>
                </Label>
                <Button fx:id="signOutBtn" layoutX="780.0" layoutY="30.0" onAction="#handleSignOutBtn" prefWidth="90.0" style="-fx-background-color: #e74c3c; -fx-cursor: hand;" text="Sign out" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </Pane>

        <GridPane hgap="25.0" layoutX="50.0" layoutY="140.0" prefHeight="450.0" prefWidth="800.0" vgap="25.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="180.0" prefHeight="180.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="180.0" prefHeight="180.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Button onAction="#handleManageInventoryBtn" prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Manage Inventory" textAlignment="CENTER" wrapText="true">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button onAction="#handlePayrollManagementBtn" prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Payroll Management" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="1">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button onAction="#handlePricingControlsBtn" prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Pricing Controls" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button onAction="#handleVIPGuestListBtn" prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="VIP Guest List" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="3">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Service Menu" wrapText="true" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Reports" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Inventory Audit" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>

                <Button prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-border-width: 2; -fx-cursor: hand;" text="Guest Reviews" wrapText="true" GridPane.columnIndex="3" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="15.0" /></font>
                </Button>
            </children>
        </GridPane>
    </children>
</AnchorPane>