<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User8Goal5Controller">
    <children>
        <Label layoutX="300.0" layoutY="20.0" text="CCTV Monitoring">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <ComboBox fx:id="camCombo" layoutX="50.0" layoutY="70.0" prefWidth="150.0" promptText="Select Camera" />
        <Button layoutX="220.0" layoutY="70.0" text="Toggle Night Vision" />
        <TableView fx:id="cctvTable" layoutX="50.0" layoutY="120.0" prefHeight="330.0" prefWidth="650.0">
            <columns>
                <TableColumn text="Zone ID" prefWidth="150" />
                <TableColumn text="View Angle" prefWidth="150" />
                <TableColumn text="Current Status" prefWidth="348" />
            </columns>
        </TableView>
        <Button fx:id="backBtn" layoutX="680.0" layoutY="20.0" text="Back" />
    </children>
</AnchorPane>