<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f1f2f6;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User8Goal2Controller">
    <children>
        <Pane prefHeight="100.0" prefWidth="900.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label layoutX="30.0" layoutY="35.0" text="INCIDENT REPORTING &amp; LOGS" textFill="#d4af37">
                    <font><Font name="System Bold" size="26.0" /></font>
                </Label>
                <Button layoutX="800.0" layoutY="38.0" onAction="#handleBackBtn" style="-fx-background-color: #d4af37; -fx-cursor: hand;" text="GO BACK" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </Pane>

        <VBox layoutX="30.0" layoutY="120.0" prefHeight="200.0" prefWidth="840.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <children>
                <HBox spacing="15.0">
                    <children>
                        <TextField fx:id="typeField" prefHeight="35.0" prefWidth="300.0" promptText="Enter Incident Type (e.g. Theft, Fire, Damage)" style="-fx-border-color: #bdc3c7;" />
                        <Label text="* Priority: High Security" textFill="#e67e22">
                            <font><Font name="System Italic" size="14.0" /></font>
                        </Label>
                    </children>
                </HBox>
                <HBox spacing="15.0">
                    <children>
                        <TextArea fx:id="descArea" prefHeight="90.0" prefWidth="640.0" promptText="Describe the incident details in depth..." style="-fx-border-color: #bdc3c7;" wrapText="true" />
                        <Button onAction="#handleSubmitBtn" prefHeight="90.0" prefWidth="160.0" style="-fx-background-color: #c0392b; -fx-cursor: hand;" text="SUBMIT REPORT" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

        <TableView fx:id="incidentTable" layoutX="30.0" layoutY="340.0" prefHeight="280.0" prefWidth="840.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="120.0" text="Report ID" />
                <TableColumn fx:id="colType" prefWidth="180.0" text="Incident Category" />
                <TableColumn fx:id="colDesc" prefWidth="538.0" text="Incident Summary &amp; Description" />
            </columns>
        </TableView>
    </children>
</AnchorPane>