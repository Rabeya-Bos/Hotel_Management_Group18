<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User7Goal1Controller">
    <children>
        <Pane prefHeight="90.0" prefWidth="900.0" style="-fx-background-color: #1a252f;">
            <children>
                <Label layoutX="30.0" layoutY="28.0" text="LUXURY HOTEL | INVENTORY MANAGEMENT" textFill="#e1b12c">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Button layoutX="800.0" layoutY="30.0" onAction="#handleBackBtn" style="-fx-background-color: #e1b12c; -fx-cursor: hand;" text="Back" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </Pane>

        <HBox layoutX="30.0" layoutY="115.0" spacing="15.0" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <children>
                <TextField fx:id="roomIdField" prefHeight="35.0" promptText="Room No" />
                <ComboBox fx:id="typeCombo" prefHeight="35.0" prefWidth="180.0" promptText="Select Category" />
                <TextField fx:id="rateField" prefHeight="35.0" promptText="Price per night" />
                <Button onAction="#handleAddBtn" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-cursor: hand;" text="Add Room" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </HBox>

        <TableView fx:id="inventoryTable" layoutX="30.0" layoutY="210.0" prefHeight="360.0" prefWidth="840.0" style="-fx-border-color: #bdc3c7;">
            <columns>
                <TableColumn fx:id="colRoomId" prefWidth="150.0" text="Room No" />
                <TableColumn fx:id="colType" prefWidth="250.0" text="Room Category" />
                <TableColumn fx:id="colRate" prefWidth="180.0" text="Rate (USD)" />
                <TableColumn fx:id="colStatus" prefWidth="258.0" text="Availability Status" />
            </columns>
        </TableView>
    </children>
</AnchorPane>