<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eror.hotelmanagementgroup18.Sumon.User8Goal4Controller">
    <children>
        <Label layoutX="250.0" layoutY="20.0" text="Emergency Response Log" textFill="RED">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <ComboBox fx:id="eTypeCombo" layoutX="50.0" layoutY="70.0" prefWidth="200.0" promptText="Emergency Type" />
        <TextField fx:id="locField" layoutX="270.0" layoutY="70.0" promptText="Location" />
        <Button layoutX="450.0" layoutY="70.0" prefWidth="250.0" style="-fx-background-color: red; -fx-text-fill: white;" text="TRIGGER EMERGENCY ALERT" />
        <TableView fx:id="eTable" layoutX="50.0" layoutY="120.0" prefHeight="330.0" prefWidth="650.0">
            <columns>
                <TableColumn text="Alert ID" prefWidth="100" />
                <TableColumn text="Type" prefWidth="150" />
                <TableColumn text="Response Status" prefWidth="398" />
            </columns>
        </TableView>
        <Button fx:id="backBtn" layoutX="680.0" layoutY="20.0" text="Back" />
    </children>
</AnchorPane>